<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Background -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_livingroom_day"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <!-- Character sprite -->
    <ImageView
        android:id="@+id/imgCharacter"
        android:layout_width="340dp"
        android:layout_height="580dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:scaleType="fitEnd"
        android:contentDescription="Character"
        android:visibility="invisible" />

    <!-- Top HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="#88000000"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/tvEventLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RANDOM EVENT"
            android:textColor="#EF9F27"
            android:textSize="10sp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 2,500"
            android:textColor="#EF9F27"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Month 1"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Bottom panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <!-- Event card -->
        <LinearLayout
            android:id="@+id/eventCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Event type badge -->
            <TextView
                android:id="@+id/tvEventType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNEXPECTED EVENT"
                android:textColor="#EF9F27"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp" />

            <!-- Event title -->
            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Event description -->
            <TextView
                android:id="@+id/tvEventDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="10dp" />

            <!-- Cost indicator -->
            <TextView
                android:id="@+id/tvEventCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#F09595"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Speaker name -->
        <TextView
            android:id="@+id/tvSpeaker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#EF9F27"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <!-- Character dialogue -->
        <LinearLayout
            android:id="@+id/dialogueBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCharacterDialogue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Choice buttons -->
        <LinearLayout
            android:id="@+id/choicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- Continue button (shown after choice made) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue ▶"
            android:textColor="#412402"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="#EF9F27"
            app:cornerRadius="26dp" />

    </LinearLayout>

</FrameLayout>