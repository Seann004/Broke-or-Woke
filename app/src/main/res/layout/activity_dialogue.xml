<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Background scene image -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_office_pantry"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Background dim overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000" />

    <!-- CHARACTER SPRITE -->
    <ImageView
        android:id="@+id/imgCharacter"
        android:layout_width="440dp"
        android:layout_height="620dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:scaleType="fitEnd"
        android:contentDescription="Character"
        android:visibility="invisible" />

    <!-- Top HUD bar -->
    <LinearLayout
        android:id="@+id/hudBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="#88000000"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="— —"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.05"
            android:fontStyle="italic" />

        <TextView
            android:id="@+id/tvBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 2,500"
            android:textColor="#EF9F27"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Month 1"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- BOTTOM PANEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/dialogueBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:minHeight="100dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvSpeakerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#EF9F27"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDialogueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:minLines="4" />

            <TextView
                android:id="@+id/tvTapHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="tap to continue ▶"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/choicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

    <!-- BIO OVERLAY — last so it renders on top -->
    <LinearLayout
        android:id="@+id/bioOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingBottom="160dp"
        android:background="#88000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/bioCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="16dp"
            android:layout_margin="16dp"
            android:translationY="0dp">

            <!-- NEW CHARACTER label -->
            <TextView
                android:id="@+id/tvBioNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW CHARACTER"
                android:textColor="#EF9F27"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="10dp" />

            <!-- Name -->
            <TextView
                android:id="@+id/tvBioName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Age / role -->
            <TextView
                android:id="@+id/tvBioAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="10dp" />

            <!-- Personality -->
            <TextView
                android:id="@+id/tvBioPersonality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="10dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="10dp" />

            <!-- Tagline / first line -->
            <TextView
                android:id="@+id/tvBioTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:fontStyle="italic"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <!-- Dismiss button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBioDismiss"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Nice to meet you  ▶"
                android:textColor="#412402"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#EF9F27"
                app:cornerRadius="22dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>