<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Background image -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_bedroom_night"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_gradient_overlay" />

    <!-- CHARACTER SPRITE — behind dialogue, centered bottom -->
    <ImageView
        android:id="@+id/imgCharacter"
        android:layout_width="380dp"
        android:layout_height="620dp"
        android:layout_marginBottom="120dp"
        android:layout_gravity="bottom|center_horizontal"
        android:src="@drawable/char_clara_neutral"
        android:scaleType="fitCenter"
        android:contentDescription="Ms. Clara"
        android:alpha="0" />

    <!-- UI layer on top of character -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp">

        <!-- Chapter label -->
        <TextView
            android:id="@+id/tvChapter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHAPTER 0"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:alpha="0"
            android:layout_marginBottom="4dp" />

        <!-- Scene title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Before we begin..."
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:alpha="0"
            android:layout_marginBottom="4dp" />

        <!-- Gold divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="36dp"
            android:layout_height="2dp"
            android:background="#EF9F27"
            android:layout_marginBottom="12dp"
            android:alpha="0" />

        <!-- Clara dialogue bubble -->
        <LinearLayout
            android:id="@+id/dialogueBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="14dp"
            android:layout_marginBottom="14dp"
            android:alpha="0">

            <TextView
                android:id="@+id/tvSpeaker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ms. Clara"
                android:textColor="#1D9E75"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvDialogue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:minLines="2" />

        </LinearLayout>

        <!-- Name input label -->
        <TextView
            android:id="@+id/tvInputLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR NAME"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:alpha="0"
            android:layout_marginBottom="6dp" />

        <!-- Name text field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/nameInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#EF9F27"
            app:hintTextColor="#EF9F27"
            app:boxBackgroundColor="#55000000"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter your name"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:inputType="textPersonName|textCapWords"
                android:maxLength="20"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Begin button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBegin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start My Story  ▶"
            android:textColor="#412402"
            android:textSize="14sp"
            android:textStyle="bold"
            android:alpha="0"
            app:backgroundTint="#EF9F27"
            app:cornerRadius="26dp" />

    </LinearLayout>

    <!-- Pregame Quiz -->
    <LinearLayout
        android:id="@+id/quizOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/quizCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="20dp"
            android:layout_margin="16dp">

            <!-- Quiz label -->
            <TextView
                android:id="@+id/tvQuizLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FINANCIAL KNOWLEDGE CHECK"
                android:textColor="#EF9F27"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <!-- Question number -->
            <TextView
                android:id="@+id/tvQuestionNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 of 3"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <!-- Question text -->
            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <!-- Option A -->
            <LinearLayout
                android:id="@+id/optionA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="10dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvOptALabel"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textColor="#EF9F27"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOptA"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Option B -->
            <LinearLayout
                android:id="@+id/optionB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="10dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvOptBLabel"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="B"
                    android:textColor="#EF9F27"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOptB"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Option C -->
            <LinearLayout
                android:id="@+id/optionC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="10dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvOptCLabel"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="C"
                    android:textColor="#EF9F27"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOptC"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Option D -->
            <LinearLayout
                android:id="@+id/optionD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="10dp"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvOptDLabel"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:textColor="#EF9F27"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOptD"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Feedback text — shown after answer -->
            <TextView
                android:id="@+id/tvQuizFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <!-- Next / Confirm button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuizNext"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Select an answer"
                android:textColor="#412402"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#EF9F27"
                app:cornerRadius="22dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>