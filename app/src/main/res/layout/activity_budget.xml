<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_office_pantry"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BB000000" />

    <!-- Main scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUDGET PLANNER"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allocate Your Salary"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="36dp"
                android:layout_height="2dp"
                android:background="#EF9F27"
                android:layout_marginBottom="16dp" />

            <!-- Salary breakdown card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvMonthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTH 1 BUDGET"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <!-- Salary row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💼 Salary this month"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvSalaryAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 2,500"
                        android:textColor="#EF9F27"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Savings carried forward row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💰 Savings carried forward"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvSavingsCarried"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#1D9E75"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Debt row — only shown if debt exists -->
                <LinearLayout
                    android:id="@+id/debtRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚠ Debt to clear"
                        android:textColor="#F09595"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvDebtAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#F09595"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#33FFFFFF"
                    android:layout_marginVertical="8dp" />

                <!-- Total available -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total available"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvSalary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 2,500"
                        android:textColor="#EF9F27"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Remaining to allocate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Remaining to allocate"
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 2,500"
                        android:textColor="#1D9E75"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Clara tip bubble -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ms. Clara  "
                    android:textColor="#1D9E75"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvClaraAdvice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Move the sliders to allocate your salary."
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- RENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🏠 Rent"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvRentAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#EF9F27"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekRent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="#EF9F27"
                    android:thumbTint="#EF9F27" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum: RM 750 (base rent)"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- FOOD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🍱 Food"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvFoodAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#EF9F27"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekFood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="#EF9F27"
                    android:thumbTint="#EF9F27" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended: RM 400–500 (16–20%)"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- TRANSPORT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🚗 Transport"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvTransportAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#EF9F27"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekTransport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="#EF9F27"
                    android:thumbTint="#EF9F27" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended: RM 200–300 (8–12%)"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- WANTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🛍️ Wants"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvWantsAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#EF9F27"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekWants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="#EF9F27"
                    android:thumbTint="#EF9F27" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended: max RM 750 (30%)"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- SAVINGS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dialogue_bubble_bg"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💰 Savings"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvSavingsAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="#1D9E75"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekSavings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2500"
                    android:progress="0"
                    android:progressTint="#1D9E75"
                    android:thumbTint="#1D9E75" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended: min RM 500 (20%)"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Warning text -->
            <TextView
                android:id="@+id/tvWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#F09595"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Confirm button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirm Budget  ▶"
                android:textColor="#412402"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#EF9F27"
                app:cornerRadius="26dp" />

        </LinearLayout>

    </ScrollView>

    <!-- No savings confirmation overlay — same style as bio card -->
    <LinearLayout
        android:id="@+id/noSavingsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/noSavingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialogue_bubble_bg"
            android:padding="20dp"
            android:layout_margin="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ WARNING"
                android:textColor="#F09595"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Savings This Month?"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You have not allocated anything to savings this month."
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Without savings, one unexpected expense — a medical bill, a car breakdown — could put you in debt immediately."
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ms. Clara went broke at 23 because she had no savings buffer. Are you sure?"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProceedNoSavings"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Proceed with RM 0 savings"
                android:textColor="#412402"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                app:backgroundTint="#EF9F27"
                app:cornerRadius="22dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoBack"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Let me adjust my budget"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                app:backgroundTint="#33FFFFFF"
                app:cornerRadius="22dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>